# Alpaca market data credentials
# Either ALPACA_* or APCA_* names are accepted by the Rust ingest crate.
ALPACA_API_KEY_ID=
ALPACA_API_SECRET_KEY=

# Historical data host. Alpaca production historical data uses data.alpaca.markets.
ALPACA_DATA_BASE_URL=https://data.alpaca.markets

# Optional feed, for example iex or sip depending on account permissions.
ALPACA_FEED=iex
